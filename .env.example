# ============================================================
# AI VEHICLE EXPIRY ENFORCEMENT SYSTEM — Environment Config
# ============================================================

# Application
APP_NAME="AI Enforcement Platform"
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-256-bit-secret-key-here
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=enforcement_db
POSTGRES_USER=enforcement_user
POSTGRES_PASSWORD=strong-password-here
DATABASE_URL=postgresql+asyncpg://enforcement_user:strong-password-here@postgres:5432/enforcement_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis-password-here
REDIS_URL=redis://:redis-password-here@redis:6379/0

# Celery
CELERY_BROKER_URL=redis://:redis-password-here@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis-password-here@redis:6379/2

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-256-bits
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI / ML
YOLO_MODEL_PATH=/app/ai/models/yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_IOU_THRESHOLD=0.45
OCR_ENGINE=easyocr
GPU_ENABLED=false
MAX_FPS=30
FRAME_SKIP=2
AI_WORKERS=2

# Camera
RTSP_TIMEOUT=10
MAX_CAMERAS=50
STREAM_BUFFER_SIZE=10

# Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@enforcement.gov
SMTP_TLS=true

SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Storage
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50
EVIDENCE_RETENTION_DAYS=90

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Monitoring
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_FORMAT=json

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME="AI Enforcement Platform"
